    <div class="nav-section-label" style="margin-top: 1.5rem;">Delivery</div>
    <div class="nav-item" onclick="showSection('validation')">Validation Plan</div>
    <div class="nav-item" onclick="showSection('deliverables')">Deliverables</div>
