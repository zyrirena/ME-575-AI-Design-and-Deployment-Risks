<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FairHire AI — Project Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400;500&family=Instrument+Serif:ital@0;1&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink: #0d0f0e;
    --paper: #f5f2ec;
    --paper2: #ede9e0;
    --accent: #1a6b45;
    --accent2: #c8e87d;
    --rule: #c4bfb4;
    --muted: #7a766d;
    --tag-bg: #e8e3d8;
    --mono: 'DM Mono', monospace;
    --serif: 'Instrument Serif', serif;
    --sans: 'Syne', sans-serif;
  }

  html { font-size: 16px; }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--mono);
    min-height: 100vh;
    display: flex;
    overflow-x: hidden;
  }

  /* ─────────────────────────────── SIDEBAR NAV ─────────────────────────────── */
  .sidebar {
    width: 280px;
    background: var(--ink);
    color: var(--paper);
    padding: 2rem 0;
    position: fixed;
    height: 100vh;
    overflow-y: auto;
    border-right: 2px solid var(--accent);
    z-index: 100;
  }

  .sidebar-logo {
    padding: 0 1.5rem 2rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 2rem;
  }

  .sidebar-logo-text {
    font-family: var(--serif);
    font-size: 1.4rem;
    font-style: italic;
    color: var(--accent2);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .nav-item {
    padding: 1rem 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    border-left: 3px solid transparent;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--paper);
  }

  .nav-item:hover {
    background: rgba(200, 232, 125, 0.1);
    border-left-color: var(--accent2);
  }

  .nav-item.active {
    background: rgba(200, 232, 125, 0.15);
    border-left-color: var(--accent2);
    font-weight: 600;
  }

  .nav-section-label {
    padding: 1.5rem 1.5rem 0.75rem;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
  }

  /* ─────────────────────────────── MAIN CONTENT ─────────────────────────────── */
  .container {
    margin-left: 280px;
    width: calc(100% - 280px);
    background: var(--paper);
  }

  .page-section {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .page-section.active {
    display: block;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* ─────────────────────────────── HEADER ─────────────────────────────── */
  .page-header {
    background: linear-gradient(135deg, rgba(26, 107, 69, 0.08) 0%, transparent 100%);
    border-bottom: 2px solid var(--ink);
    padding: 3rem 4rem;
    position: relative;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(0deg, transparent, transparent 47px, var(--rule) 47px, var(--rule) 48px),
      repeating-linear-gradient(90deg, transparent, transparent 47px, var(--rule) 47px, var(--rule) 48px);
    opacity: 0.35;
    pointer-events: none;
  }

  .header-meta {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-family: var(--serif);
    font-size: 2.8rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    position: relative;
  }

  .page-title em {
    color: var(--accent);
    font-style: italic;
  }

  .page-subtitle {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--muted);
    margin-top: 1rem;
    max-width: 600px;
  }

  /* ─────────────────────────────── CONTENT ─────────────────────────────── */
  .page-content {
    padding: 3rem 4rem;
    max-width: 1100px;
  }

  .content-section {
    margin-bottom: 3.5rem;
  }

  .content-section h2 {
    font-family: var(--sans);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--ink);
  }

  .content-section h3 {
    font-family: var(--sans);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.5rem 0 0.75rem;
  }

  .content-section p {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1rem;
    color: var(--ink);
  }

  .content-section ul {
    font-family: var(--sans);
    font-size: 0.95rem;
    margin-left: 1.5rem;
    margin-bottom: 1rem;
    line-height: 1.8;
  }

  .content-section li {
    margin-bottom: 0.6rem;
  }

  /* ─────────────────────────────── GRID CARDS ─────────────────────────────── */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin: 1.5rem 0;
  }

  .card {
    background: var(--paper2);
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    padding: 1.75rem;
    border-radius: 2px;
  }

  .card h4 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--ink);
  }

  .card p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ─────────────────────────────── TABLES ─────────────────────────────── */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border: 1px solid var(--rule);
    margin: 1.5rem 0;
  }

  .data-table th {
    background: var(--paper2);
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.85rem 1rem;
    text-align: left;
    border-bottom: 2px solid var(--rule);
    font-weight: 600;
  }

  .data-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--rule);
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--ink);
  }

  .data-table tbody tr:hover {
    background: var(--paper2);
  }

  .data-table tbody tr:last-child td {
    border-bottom: none;
  }

  /* ─────────────────────────────── STATUS BADGES ─────────────────────────────── */
  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.75rem;
    border-radius: 2px;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .status-checked {
    background: rgba(26, 107, 69, 0.2);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .status-pending {
    background: rgba(224, 160, 32, 0.2);
    color: #b8860b;
    border: 1px solid #d4a520;
  }

  /* ─────────────────────────────── CALLOUT ─────────────────────────────── */
  .callout {
    border-left: 4px solid var(--accent);
    background: rgba(26, 107, 69, 0.08);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 2px;
  }

  .callout-title {
    font-family: var(--sans);
    font-weight: 700;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .callout-text {
    font-family: var(--sans);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--muted);
  }

  /* ─────────────────────────────── PILL TAGS ─────────────────────────────── */
  .pill {
    display: inline-block;
    background: var(--tag-bg);
    border: 1px solid var(--rule);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
  }

  /* ─────────────────────────────── FOOTER ─────────────────────────────── */
  .page-footer {
    background: var(--ink);
    color: var(--paper);
    padding: 2rem 4rem;
    border-top: 2px solid var(--ink);
    margin-top: 4rem;
    margin-left: 280px;
  }

  .footer-content {
    max-width: 1100px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .footer-section h3 {
    font-family: var(--serif);
    font-size: 1.1rem;
    margin-bottom: 1rem;
  }

  .footer-text {
    font-family: var(--sans);
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(245, 242, 236, 0.85);
  }

  /* ─────────────────────────────── RESPONSIVE ─────────────────────────────── */
  @media (max-width: 1024px) {
    .sidebar {
      width: 200px;
    }
    .container {
      margin-left: 200px;
      width: calc(100% - 200px);
    }
    .page-footer {
      margin-left: 200px;
    }
    .card-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .sidebar {
      width: 100%;
      height: auto;
      position: relative;
      border-right: none;
      border-bottom: 2px solid var(--accent);
    }
    .container {
      margin-left: 0;
      width: 100%;
    }
    .page-footer {
      margin-left: 0;
    }
    .page-header, .page-content {
      padding: 2rem 1.5rem;
    }
    .page-title {
      font-size: 2rem;
    }
    .nav-item {
      display: inline-block;
      padding: 0.5rem 1rem;
      border-left: none;
      border-bottom: 2px solid transparent;
    }
    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .footer-content {
      grid-template-columns: 1fr;
    }
  }

  /* Code & Links */
  code {
    font-family: var(--mono);
    background: var(--tag-bg);
    padding: 0.1em 0.4em;
    border-radius: 2px;
    border: 1px solid var(--rule);
    color: var(--accent);
  }

  a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    transition: all 0.2s ease;
  }

  a:hover {
    background: var(--tag-bg);
    padding: 0 0.3rem;
  }

  /* Scrollbar styling */
  .sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .sidebar::-webkit-scrollbar-track {
    background: var(--ink);
  }

  .sidebar::-webkit-scrollbar-thumb {
    background: var(--rule);
    border-radius: 3px;
  }

  .sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--accent);
  }
</style>
</head>
<body>

<!-- SIDEBAR NAVIGATION -->
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-text">FairHire<br>AI</div>
  </div>

  <div class="sidebar-nav">
    <div class="nav-section-label">Project Overview</div>
    <div class="nav-item active" onclick="showSection('overview')">Project Overview</div>
    <div class="nav-item" onclick="showSection('problem')">Problem Context</div>
    <div class="nav-item" onclick="showSection('stakeholders')">Stakeholders</div>

    <div class="nav-section-label" style="margin-top: 1.5rem;">System Design</div>
    <div class="nav-item" onclick="showSection('scope')">System Scope</div>
    <div class="nav-item" onclick="showSection('risk')">Risk Framing</div>
